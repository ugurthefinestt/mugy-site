      .gallery-wrap{display:grid;grid-template-columns:1.1fr .9fr;gap:22px;margin-top:38px}.gallery-big,.gallery-small{display:grid;gap:20px}.gallery-hero{min-height:390px;overflow:hidden;padding:0}.gallery-inner{height:100%;background:linear-gradient(135deg,rgba(202,168,121,.16),rgba(124,143,163,.18));display:flex;align-items:center;justify-content:center;position:relative}.gallery-inner:before{content:"";position:absolute;inset:22px;border-radius:24px;border:1px dashed rgba(255,255,255,.22)}.gallery-tile{min-height:185px}
      .banner{background:linear-gradient(135deg,#162535 0%,#0f1822 55%,#1c3040 100%);overflow:hidden;position:relative}.banner:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,rgba(202,168,121,.16),transparent 20%)}
