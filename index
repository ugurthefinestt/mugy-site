      .hero-grid{position:relative;display:grid;grid-template-columns:1.05fr .95fr;gap:34px;align-items:center;padding:115px 0 105px}.hero-copy h2{font-size:clamp(40px,6vw,66px);line-height:1.05;margin:18px 0 0}.lead{margin-top:20px;color:var(--muted);font-size:18px;line-height:1.8;max-width:780px}
